@model IEnumerable<Web.ViewModels.AdvogadoViewModel>
@using System.Linq

@{
    ViewBag.Title = "Advogados";
    var listaAdvogados = Model != null ? Model.ToList() : new List<Web.ViewModels.AdvogadoViewModel>();
}

<div class="container py-4">
    
    <div class="row justify-content-center">
        <div class="col-12">

            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <div class="card-header bg-white border-0 py-4 px-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h2 class="mb-1 fw-bold text-dark">Listagem de Advogados</h2>
                            <p class="text-muted mb-0">Gerencie os advogados cadastrados no sistema</p>
                        </div>

                        <a href="@Url.Action("Formulario", "Advogado")"
                           class="btn btn-primary px-4 py-2 rounded-3 fw-semibold shadow-sm">
                            <i class="fa-solid fa-plus me-2"></i>Novo Advogado
                        </a>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="table-responsive.">
                        <table id="tblAdvogados" class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="px-4 py-3 text-dark fw-semibold">Nome</th>
                                    <th class="px-3 py-3 text-dark fw-semibold">Senioridade</th>
                                    <th class="px-3 py-3 text-dark fw-semibold">Endereço</th>
                                    <th class="px-4 py-3 text-center text-dark fw-semibold" style="width: 180px;">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (listaAdvogados.Count > 0)
                                {
                                    foreach (var item in listaAdvogados)
                                    {
                                        var badgeClass = "bg-secondary";

                                        if (item.Senioridade.ToString() == "Junior")
                                        {
                                            badgeClass = "bg-info text-dark";
                                        }
                                        else if (item.Senioridade.ToString() == "Pleno")
                                        {
                                            badgeClass = "bg-warning text-dark";
                                        }
                                        else if (item.Senioridade.ToString() == "Senior")
                                        {
                                            badgeClass = "bg-success";
                                        }

                                        <tr>
                                            <td class="px-4 py-3">
                                                <div class="fw-semibold text-dark">@item.Nome</div>
                                            </td>

                                            <td class="px-3 py-3">
                                                <span class="badge @badgeClass rounded-pill px-3 py-2 badge-senioridade">
                                                    @item.Senioridade
                                                </span>
                                            </td>

                                            <td class="px-3 py-3">
                                                <div class="d-flex flex-column gap-1">
                                                    <div class="fw-semibold text-dark">
                                                        @item.Logradouro
                                                        <span class="text-muted fw-normal">nº @item.Numero</span>
                                                    </div>

                                                    <div class="text-muted small">
                                                        @item.Bairro - @item.Estado
                                                    </div>

                                                    <div class="text-muted small">
                                                        CEP: @item.Cep
                                                        @if (!string.IsNullOrEmpty(item.Complemento))
                                                        {
                                                            <span> • Compl.: @item.Complemento</span>
                                                        }
                                                    </div>
                                                </div>
                                            </td>

                                            <td class="px-4 py-3 text-center">
                                                <div class="d-flex justify-content-center gap-2">
                                                    <a href="@Url.Action("Formulario", "Advogado", new { id = item.Id })"
                                                       class="btn btn-sm btn-outline-primary rounded-3 px-3"
                                                       title="Editar">
                                                        <i class="fa-solid fa-pen-to-square me-1"></i>
                                                    </a>

                                                    @using (Html.BeginForm("Excluir", "Advogado", new { id = item.Id }, FormMethod.Post, new { onsubmit = "return confirm('Deseja excluir este advogado?');", style = "display:inline;" }))
                                                    {
                                                        @Html.AntiForgeryToken()

                                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3 px-3" title="Excluir">
                                                            <i class="fa-solid fa-trash me-1"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section scripts{
    <script>
        $(document).ready(function () {
            $('#tblAdvogados').DataTable({
                autoWidth: false,
                scrollX: false,
                responsive: false,
                language: {
                    emptyTable: "Nenhum advogado cadastrado.",
                    zeroRecords: "Nenhum advogado encontrado",
                    info: "Mostrando de _START_ até _END_ de _TOTAL_ registros",
                    infoEmpty: "Mostrando 0 até 0 de 0 registros",
                    infoFiltered: "(filtrado de _MAX_ registros no total)",
                    lengthMenu: "Mostrar _MENU_ registros",
                    loadingRecords: "Carregando...",
                    processing: "Processando...",
                    search: "Buscar:",
                    paginate: {
                        first: "Primeiro",
                        last: "Último",
                        next: "Próximo",
                        previous: "Anterior"
                    }
                },
                pageLength: 5,
                lengthMenu: [5, 10, 25, 50],
                columnDefs: [
                    { orderable: false, targets: 3 }
                ],
                ordering: true,
                searching: true,
                paging: true,
                info: true,
                initComplete: function () {
                    $('.dataTables_length select').addClass('form-select form-select-sm');
                }
            });
        });
    </script>
}